	const storiesList = document.getElementById('stories-list');
	const tabs = document.querySelectorAll('.tui-tab');
	const tuiWindow = document.getElementById('tui-window');
	const tuiStatusText = document.querySelector('#tui-status .status-text');

	// Render stories list
	function renderCategory(catName) {
		if (!storiesList) return;
		storiesList.innerHTML = '';
		const items = stories[catName];

		items.forEach((item, index) => {
			const itemDiv = document.createElement('div');
			itemDiv.className = `tui-item ${index === selectedIndex ? 'selected' : ''}`;

			const readPrefix = item.read ? '✓ ' : '';
			const itemTitleClass = item.read ? 'style="color: var(--gray);"' : '';
			
			// Build metadata string
			let metaHtml = '';
			if (item.read && index !== selectedIndex) {
				metaHtml = `<span class="meta-pts" style="color: var(--gray);">${item.pts} pts</span> · <span style="color: var(--gray);">by ${item.author}</span> · <span class="meta-time">${item.time}</span> · <span class="meta-comments" style="color: var(--gray);">${item.comments} comments</span>`;
			} else {
				metaHtml = `<span class="meta-pts">${item.pts} pts</span> · by <span class="meta-author">${item.author}</span> · <span class="meta-time">${item.time}</span> · <span class="meta-comments">${item.comments} comments</span>`;
			}

			itemDiv.innerHTML = `
				<div class="tui-item-body">
					<div class="tui-item-title" ${itemTitleClass}>${readPrefix}${item.title}</div>
					<div class="tui-item-meta">${metaHtml}</div>
				</div>
			`;

			itemDiv.addEventListener('click', () => {
				if (selectedIndex === index) {
					// Second click opens comments
					showComments(item);
				} else {
					selectedIndex = index;
					updateSelection();
				}
			});

			storiesList.appendChild(itemDiv);
		});
	}

	// Update selection class and scroll into view
	function updateSelection() {
		if (!storiesList) return;
		const itemElems = storiesList.querySelectorAll('.tui-item');
		itemElems.forEach((elem, index) => {
			if (index === selectedIndex) {
				elem.classList.add('selected');
				elem.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
			} else {
				elem.classList.remove('selected');
			}
		});
		
		// Refresh rendering to update metadata coloring on selection change
		const items = stories[activeCategory];
		const itemElemsMeta = storiesList.querySelectorAll('.tui-item-meta');
		itemElemsMeta.forEach((metaElem, index) => {
			const item = items[index];
			if (item.read && index !== selectedIndex) {
				metaElem.innerHTML = `<span class="meta-pts" style="color: var(--gray);">${item.pts} pts</span> · <span style="color: var(--gray);">by ${item.author}</span> · <span class="meta-time">${item.time}</span> · <span class="meta-comments" style="color: var(--gray);">${item.comments} comments</span>`;
			} else {
				metaElem.innerHTML = `<span class="meta-pts">${item.pts} pts</span> · by <span class="meta-author">${item.author}</span> · <span class="meta-time">${item.time}</span> · <span class="meta-comments">${item.comments} comments</span>`;
			}
		});
	}

	// Switch category tab
	function switchTab(catName) {
		if (inCommentsView) {
			exitComments();
		}
		activeCategory = catName;
		selectedIndex = 0;
		tabs.forEach(t => {
			if (t.getAttribute('data-cat') === catName) {
				t.classList.add('active');
			} else {
				t.classList.remove('active');
			}
		});
		renderCategory(catName);
	}

	// Show detailed comments view
	function showComments(item) {
		inCommentsView = true;
		item.read = true; // Mark as read
		
		// Update footer bar keys
		const footerBar = document.getElementById('tui-footer-bar');
		if (footerBar) {
			footerBar.innerHTML = `
				<span class="footer-key">q/esc</span> <span class="footer-desc">back</span>  |  
				<span class="footer-key">j/k</span> <span class="footer-desc">scroll comments</span>
			`;
		}

		if (storiesList) {
			storiesList.innerHTML = '';
			
			const container = document.createElement('div');
			container.className = 'tui-comments-container';

			const header = document.createElement('div');
			header.className = 'tui-comments-header';
			
			const backBtn = document.createElement('div');
			backBtn.className = 'tui-back-button';
			backBtn.innerHTML = `❮ Back to list (esc)`;
			backBtn.addEventListener('click', exitComments);
			
			const title = document.createElement('div');
			title.className = 'tui-comment-story-title';
			title.innerText = item.title;

			header.appendChild(backBtn);
			header.appendChild(title);
			container.appendChild(header);

			const commentsList = document.createElement('div');
			commentsList.className = 'tui-comments-list';

			if (item.commentsList && item.commentsList.length > 0) {
				const indentColors = ['#ff6600', '#00f0ff', '#85a5ff', '#adff2f', '#ff00ff'];
				item.commentsList.forEach(comment => {
					const commentDiv = document.createElement('div');
					commentDiv.className = 'tui-comment-item';
					commentDiv.style.marginLeft = `${comment.depth * 16}px`;
					if (comment.depth > 0) {
						commentDiv.style.borderLeft = `1px solid ${indentColors[(comment.depth - 1) % indentColors.length]}`;
						commentDiv.style.paddingLeft = '10px';
					}

					commentDiv.innerHTML = `
						<div class="tui-comment-meta">
							by <span class="meta-author">${comment.author}</span> · <span class="meta-time">${comment.time}</span>
						</div>
						<div class="tui-comment-body">${comment.text}</div>
					`;
					commentsList.appendChild(commentDiv);
				});
			} else {
				const emptyDiv = document.createElement('div');
				emptyDiv.style.color = 'var(--gray)';
				emptyDiv.style.fontSize = '13px';
				emptyDiv.style.padding = '20px 0';
				emptyDiv.innerText = 'No comments yet.';
				commentsList.appendChild(emptyDiv);
			}

			container.appendChild(commentsList);
			storiesList.appendChild(container);
		}
	}

	// Exit comments view and return to stories list
	function exitComments() {
		inCommentsView = false;
		const footerBar = document.getElementById('tui-footer-bar');
		if (footerBar) {
			footerBar.innerHTML = `
				<span class="footer-key">q</span> <span class="footer-desc">quit</span>  |  
				<span class="footer-key">tab</span> <span class="footer-desc">category</span>  |  
				<span class="footer-key">j/k</span> <span class="footer-desc">navigate</span>  |  
				<span class="footer-key">enter</span> <span class="footer-desc">comments</span>  |  
				<span class="footer-key">w</span> <span class="footer-desc">post</span>  |  
				<span class="footer-key">/</span> <span class="footer-desc">search</span>
			`;
		}
		renderCategory(activeCategory);
	}

	// Tab switching click event listeners
	tabs.forEach(tab => {
		tab.addEventListener('click', () => {
			const cat = tab.getAttribute('data-cat');
			switchTab(cat);
		});
	});

	// Keyboard TUI Controls
	if (tuiWindow) {
		// Keyboard focus indicators
		tuiWindow.addEventListener('focus', () => {
			if (tuiStatusText) {
				tuiStatusText.innerText = 'KEYBOARD ACTIVE (Use vim keys)';
				tuiStatusText.style.color = 'var(--green)';
			}
		});

		tuiWindow.addEventListener('blur', () => {
			if (tuiStatusText) {
				tuiStatusText.innerText = 'Interactive TUI (Click to focus)';
				tuiStatusText.style.color = '';
			}
		});

		tuiWindow.addEventListener('keydown', (e) => {
			const keysToIntercept = ['ArrowUp', 'ArrowDown', 'j', 'k', 'Enter', 'Escape', 'q', '1', '2', '3', '4', '5', 'Tab'];
			if (keysToIntercept.includes(e.key)) {
				e.preventDefault();
				e.stopPropagation();
			}

			if (inCommentsView) {
				if (e.key === 'Escape' || e.key === 'q') {
					exitComments();
				}
				const commentsContainer = document.querySelector('.tui-comments-container');
				if (commentsContainer) {
					if (e.key === 'j' || e.key === 'ArrowDown') {
						commentsContainer.scrollTop += 24;
					} else if (e.key === 'k' || e.key === 'ArrowUp') {
						commentsContainer.scrollTop -= 24;
					}
				}
			} else {
				const items = stories[activeCategory];
				if (e.key === 'j' || e.key === 'ArrowDown') {
					if (selectedIndex < items.length - 1) {
						selectedIndex++;
						updateSelection();
					}
				} else if (e.key === 'k' || e.key === 'ArrowUp') {
					if (selectedIndex > 0) {
						selectedIndex--;
						updateSelection();
					}
				} else if (e.key === 'Enter') {
					showComments(items[selectedIndex]);
				} else if (e.key === '1') {
					switchTab('top');
				} else if (e.key === '2') {
					switchTab('new');
				} else if (e.key === '3') {
					switchTab('best');
				} else if (e.key === '4') {
					switchTab('ask');
				} else if (e.key === '5') {
					switchTab('show');
				} else if (e.key === 'Tab') {
					const tabsList = ['top', 'new', 'best', 'ask', 'show'];
					const nextIndex = (tabsList.indexOf(activeCategory) + 1) % tabsList.length;
					switchTab(tabsList[nextIndex]);
				}
			}
		});
	}

	// Initial render
	renderCategory('top');

	// System Boot Preloader Dismissal
	window.addEventListener('DOMContentLoaded', () => {
		const preloader = document.getElementById('system-preloader');
		if (preloader) {
			setTimeout(() => {
				preloader.classList.add('fade-out');
			}, 1300);
		}
	});

	// Copy to clipboard function
	const copyBtn = document.getElementById('copy-btn');
	const copyCommand = document.getElementById('install-command');
	const copyBtnText = document.getElementById('copy-btn-text');

	if (copyBtn && copyCommand && copyBtnText) {
		copyBtn.addEventListener('click', () => {
			const commandText = copyCommand.innerText;
			navigator.clipboard.writeText(commandText).then(() => {
				copyBtnText.innerText = 'Copied!';
				copyBtn.style.borderColor = 'var(--green)';
				copyBtn.style.color = 'var(--green)';
				setTimeout(() => {
					copyBtnText.innerText = 'Copy';
					copyBtn.style.borderColor = '';
					copyBtn.style.color = '';
				}, 2000);
			}).catch(err => {
				console.error('Copy failed: ', err);
			});
		});
	}

	// Feature Cards mouse spotlight glow effect
	const featureCards = document.querySelectorAll('.feature-card');
	featureCards.forEach(card => {
		card.addEventListener('mousemove', e => {
			const rect = card.getBoundingClientRect();
			const x = e.clientX - rect.left;
			const y = e.clientY - rect.top;
			(card as HTMLElement).style.setProperty('--mouse-x', `${x}px`);
			(card as HTMLElement).style.setProperty('--mouse-y', `${y}px`);
		});
	});

	// Scroll Reveal Animation implementation using IntersectionObserver
	const revealElements = document.querySelectorAll('.reveal');
	
	const observerOptions = {
		root: null,
		rootMargin: '0px',
		threshold: 0.15
	};

	const revealObserver = new IntersectionObserver((entries, observer) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				entry.target.classList.add('visible');
				observer.unobserve(entry.target);
			}
		});
	}, observerOptions);

	revealElements.forEach(element => {
		revealObserver.observe(element);
	});

	// Keybindings Interactive Filter
	const keyTabs = document.querySelectorAll('.key-tab');
	const keyItems = document.querySelectorAll('.key-item');

	keyTabs.forEach(tab => {
		tab.addEventListener('click', () => {
			keyTabs.forEach(t => t.classList.remove('active'));
			tab.classList.add('active');

			const group = tab.getAttribute('data-group');
			keyItems.forEach(item => {
				if (group === 'all' || item.getAttribute('data-group') === group) {
					item.classList.remove('hidden');
				} else {
					item.classList.add('hidden');
				}
			});
		});
	});

	// FAQ Accordion Toggle
	const faqTriggers = document.querySelectorAll('.faq-trigger');

	faqTriggers.forEach(trigger => {
		trigger.addEventListener('click', () => {
			const item = trigger.closest('.faq-item');
			if (!item) return;
			const content = item.querySelector('.faq-content') as HTMLElement;
			if (!content) return;
			const isActive = item.classList.contains('active');

			// Close all other FAQ items
			document.querySelectorAll('.faq-item').forEach(i => {
				if (i !== item) {
					i.classList.remove('active');
					const c = i.querySelector('.faq-content') as HTMLElement;
					if (c) c.style.maxHeight = '';
				}
			});

			if (isActive) {
				item.classList.remove('active');
				content.style.maxHeight = '';
			} else {
				item.classList.add('active');
				content.style.maxHeight = content.scrollHeight + 'px';
			}
		});
	});

	// Reboot / Back to Top Button
	const rebootBtn = document.getElementById('reboot-btn');
	const appContainer = document.getElementById('app-container');
	const preloader = document.getElementById('system-preloader');
	const preloaderLines = document.querySelector('.preloader-lines');
	const preloaderProgress = document.querySelector('.preloader-progress-fill');

	// Show/hide reboot button on scroll
	window.addEventListener('scroll', () => {
		if (window.scrollY > 400) {
			rebootBtn?.classList.add('visible');
		} else {
			rebootBtn?.classList.remove('visible');
		}
	});

	rebootBtn?.addEventListener('click', () => {
		if (!appContainer || !preloader) return;

		// 1. Trigger deconstruct (dissolve) transition
		appContainer.classList.add('deconstruct');

		// 2. Prepare preloader lines for reboot text
		if (preloaderLines) {
			preloaderLines.innerHTML = `
				<div class="preloader-line line-1">❯ reboot sequence triggered...</div>
				<div class="preloader-line line-2">❯ flushing virtual memory cache...</div>
				<div class="preloader-line line-3">❯ compiling DOM layout trees...</div>
				<div class="preloader-line line-4">❯ system online (rebuilt)</div>
			`;
		}

		// Reset progress bar animation
		if (preloaderProgress) {
			const el = preloaderProgress as HTMLElement;
			el.style.animation = 'none';
			el.offsetHeight; /* trigger reflow */
			el.style.animation = '';
		}

		// 3. Show preloader (undim)
		preloader.classList.remove('fade-out');

		// 4. Scroll to top and restore app state
		setTimeout(() => {
			window.scrollTo({ top: 0 });
			appContainer.classList.remove('deconstruct');
			
			// Re-trigger scroll reveals
			document.querySelectorAll('.reveal').forEach(el => {
				el.classList.remove('visible');
			});
			// Re-initialize reveals since they should stagger back in
			const revealElements = document.querySelectorAll('.reveal');
			revealElements.forEach(element => {
				revealObserver.observe(element);
			});
		}, 600); // Trigger mid-way during dissolve transition

		// 5. Fade preloader back out
		setTimeout(() => {
			preloader.classList.add('fade-out');
		}, 1800);
	});
</script>
