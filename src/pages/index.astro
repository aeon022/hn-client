<script>
	// Mock Hacker News Stories Data
	const stories = {
		top: [
			{ title: "Show HN: hn-client — Hacker News directly in the terminal", pts: 256, author: "gweiher", time: "vor 2 Std.", comments: 32, read: true },
			{ title: "DuckDB Internals: Why Is DuckDB Fast? (Part 1)", pts: 187, author: "greybeam", time: "vor 11 Std.", comments: 88, read: false },
			{ title: "Project Valhalla, Explained: How a Decade of Work Arrives in JDK 28", pts: 116, author: "skogstokig", time: "vor 17 Std.", comments: 83, read: false }
		],
		new: [
			{ title: "Show HN: WebGL canvas particles layout", pts: 12, author: "creative_coder", time: "vor 5 Min.", comments: 3, read: false },
			{ title: "My experience writing Go code without pointers", pts: 45, author: "go_pioneer", time: "vor 48 Min.", comments: 19, read: false },
			{ title: "Why I still use w3m in 2026", pts: 98, author: "term_guru", time: "vor 1 Std.", comments: 41, read: true }
		],
		best: [
			{ title: "Why Is Apple's Silicon So Fast? (2020)", pts: 894, author: "tech_mind", time: "vor 2 Tagen", comments: 312, read: false },
			{ title: "Show HN: Are You in the Weights?", pts: 402, author: "turtlesoup", time: "vor 18 Std.", comments: 226, read: false },
			{ title: "What I learned from reading the UNIX v6 source code", pts: 512, author: "sys_eng", time: "vor 1 Tag", comments: 92, read: true }
		],
		ask: [
			{ title: "Ask HN: What is your favorite terminal tool?", pts: 143, author: "shell_lover", time: "vor 5 Std.", comments: 98, read: false },
			{ title: "Ask HN: Why did you switch from Python to Go?", pts: 210, author: "py_convert", time: "vor 12 Std.", comments: 154, read: false },
			{ title: "Ask HN: Best resources to learn Bubble Tea framework?", pts: 87, author: "tui_enthusiast", time: "vor 1 Tag", comments: 22, read: true }
		],
		show: [
			{ title: "Show HN: hn-client — Hacker News directly in the terminal", pts: 256, author: "gweiher", time: "vor 2 Std.", comments: 32, read: true },
			{ title: "Show HN: Talos – Open-source WASM interpreter for Lean", pts: 69, author: "mfornet", time: "vor 13 Std.", comments: 15, read: false },
			{ title: "Show HN: Interactive terminal simulator on a landing page", pts: 145, author: "astro_dev", time: "vor 1 Tag", comments: 9, read: false }
		]
	};

	// DOM Elements
	const storiesList = document.getElementById('stories-list');
	const tabs = document.querySelectorAll('.tui-tab');
	const tuiFooterBar = document.getElementById('tui-footer-bar');

	// Render stories list
	function renderCategory(catName) {
		if (!storiesList) return;
		storiesList.innerHTML = '';
		const items = stories[catName];

		items.forEach((item, index) => {
			const itemDiv = document.createElement('div');
			itemDiv.className = `tui-item ${index === 0 ? 'selected' : ''}`;

			const readPrefix = item.read ? '✓ ' : '';
			const itemTitleClass = item.read ? 'style="color: var(--gray);"' : '';
			
			// Build metadata string
			let metaHtml = '';
			if (item.read && index !== 0) {
				// Dimmed for read, unselected
				metaHtml = `<span class="meta-pts" style="color: var(--gray);">${item.pts} pts</span> · <span style="color: var(--gray);">von ${item.author}</span> · <span class="meta-time">${item.time}</span> · <span class="meta-comments" style="color: var(--gray);">${item.comments} Kommentare</span>`;
			} else {
				// Regular colored metadata
				metaHtml = `<span class="meta-pts">${item.pts} pts</span> · von <span class="meta-author">${item.author}</span> · <span class="meta-time">${item.time}</span> · <span class="meta-comments">${item.comments} Kommentare</span>`;
			}

			itemDiv.innerHTML = `
				<div class="tui-item-body">
					<div class="tui-item-title" ${itemTitleClass}>${readPrefix}${item.title}</div>
					<div class="tui-item-meta">${metaHtml}</div>
				</div>
			`;
			storiesList.appendChild(itemDiv);
		});
	}

	// Tab switching event listeners
	tabs.forEach(tab => {
		tab.addEventListener('click', () => {
			tabs.forEach(t => t.classList.remove('active'));
			tab.classList.add('active');
			const cat = tab.getAttribute('data-cat');
			renderCategory(cat);
		});
	});

	// Initial render
	renderCategory('top');

	// Copy to clipboard function
	const copyBtn = document.getElementById('copy-btn');
	const copyCommand = document.getElementById('install-command');
	const copyBtnText = document.getElementById('copy-btn-text');

	if (copyBtn && copyCommand && copyBtnText) {
		copyBtn.addEventListener('click', () => {
			const commandText = copyCommand.innerText;
			navigator.clipboard.writeText(commandText).then(() => {
				copyBtnText.innerText = 'Kopiert!';
				copyBtn.style.borderColor = 'var(--green)';
				copyBtn.style.color = 'var(--green)';
				setTimeout(() => {
					copyBtnText.innerText = 'Kopieren';
					copyBtn.style.borderColor = '';
					copyBtn.style.color = '';
				}, 2000);
			}).catch(err => {
				console.error('Copy failed: ', err);
			});
		});
	}
</script>
